### your code here
repRandomComm <- function(years, sys.traits){
## This function 1) shuffles year 1 using randomizeTraits function
## 2) loops over the remaining years, row binding the data priod year each time
## 3) takes the mean of the traits across years, and returns the value
## shuffle year 1
random.traits <- randomizeTraits(yr = years[1], data = sys.traits)
## rbind on the other years
for (yr in years[-1]) {
new.year <- randomizeTraits(yr = yr, data = sys.traits)
random.traits <- rbind(random.traits, new.year)
}
## take the mean across years
mean.years <- random.traits %>%
group_by(ShuffleSiteStatus) %>%
summarise(mean_body_size=mean(mean_body_size))
return(mean.years)
}
### your code here
